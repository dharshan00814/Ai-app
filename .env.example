# Environment Template - Copy to .env and fill in your values

# OpenAI API Configuration
OPENAI_API_KEY=sk-proj-your-api-key-here

# Google Gemini API Configuration
GOOGLE_API_KEY=your-google-api-key-here

# AI Provider Selection: google | openai | ollama
AI_SERVICE=google

# Ollama Local LLM Configuration
# Example models: llama3.2, mistral, phi3
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=45000

# Server Configuration
PORT=3000
NODE_ENV=development

# Principal Email (for notifications)
PRINCIPAL_EMAIL=principal@company.com

# Optional: Database Configuration (for future use)
# DB_TYPE=mongodb
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbname

# Optional: Email Configuration (for sending approvals)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Optional: File Upload Settings
# MAX_FILE_SIZE=10485760
# UPLOADS_DIR=./uploads

# Optional: Logging
# LOG_LEVEL=info
# LOG_FILE=./logs/app.log

# Optional: Security
# CORS_ORIGIN=http://localhost:3000
# JWT_SECRET=your-secret-key-here

# Optional: API Rate Limiting
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
