# .gitignore - Exclude files from version control

# Dependencies
node_modules/
npm-debug.log*
package-lock.json
yarn.lock

# Environment variables
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*.swn
*~
.DS_Store

# Logs
logs/
*.log
npm-debug.log*
lerna-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
.nyc_output/

# Build
dist/
build/
out/

# Temporary files
temp/
tmp/
.cache/

# OS
.DS_Store
Thumbs.db

# API Keys and secrets (important!)
.env
.env.local
.env.*.local
secret*.js
config/keys*.js

# Upload directories (use gitkeep instead)
uploads/*
!uploads/.gitkeep

# Database files
*.db
*.sqlite
*.sqlite3

# Editor directories and files
.idea/
.project
.classpath
*.launch
.settings/
*.sublime-workspace

# Misc
.eslintcache
dist_ssr/
*.local
